@page "{id:guid}"
@model DuSoleil.Web.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = "Order details";
    var o = Model.Order!;
}

<div class="page-wrap">
    <nav class="breadcrumbs">
        <a asp-page="/Orders/Index">Orders</a> <span>/</span> <span>@o.Id.ToString()[..8]</span>
    </nav>
    <h1>Order @o.Id.ToString()[..8]</h1>
    <p class="muted">@o.OrderDateUtc.ToLocalTime().ToString("g") · @o.Status</p>

    <table class="admin-table">
        <thead>
            <tr><th>Product</th><th>Price</th><th>Qty</th><th>Sum</th></tr>
        </thead>
        <tbody>
        @foreach (var i in o.Items)
        {
            <tr>
                <td>
                    <div class="order-item-cell">
                        @if (!string.IsNullOrEmpty(i.ProductImageUrl))
                        {
                            <img src="@i.ProductImageUrl" alt="" width="48" height="48" />
                        }
                        <div>
                            <strong>@i.ProductName</strong>
                            <div class="muted">@i.CategoryName</div>
                        </div>
                    </div>
                </td>
                <td>$@i.ProductPrice.ToString("0.00")</td>
                <td>@i.Quantity</td>
                <td>$@i.TotalPrice.ToString("0.00")</td>
            </tr>
        }
        </tbody>
    </table>
    <p class="cart-total"><strong>Total: $@o.TotalAmount.ToString("0.00")</strong></p>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert-error">@Model.Error</div>
    }

    <div class="order-actions">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form method="post" asp-page-handler="Repeat">
                <input type="hidden" name="id" value="@o.Id" />
                <button class="btn btn-primary" type="submit">Buy again</button>
            </form>
        }
        <a class="btn btn-ghost" asp-page="/Index">Continue shopping</a>
    </div>
</div>
