@page
@model DuSoleil.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="page-wrap auth-box">
    <h1>Create account</h1>
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert-error">@Model.Error</div>
    }
    <form method="post" class="admin-form">
        <label>Name <input asp-for="Name" required /></label>
        <label>Email <input asp-for="Email" type="email" required /></label>
        <label>Login <input asp-for="Login" required /></label>
        <label>Password <input asp-for="Password" type="password" required /></label>
        <button class="btn btn-primary" type="submit">Sign up</button>
    </form>
    <p>Already have an account? <a asp-page="/Account/Login">Sign in</a></p>
</div>
