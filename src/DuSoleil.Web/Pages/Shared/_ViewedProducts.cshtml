@model List<ProductCardVm>
@*
  Блок «Recently viewed» — homework _ViewedProducts, стиль витрины Du Soleil / Amazon.
*@
@if (Model is { Count: > 0 })
{
    <section class="section viewed-section">
        <div class="section-head">
            <h2>Recently viewed</h2>
            <span class="muted">Товары, которые вы недавно смотрели</span>
        </div>
        <div class="product-row">
            @foreach (var p in Model)
            {
                <partial name="_ProductCard" model="p" />
            }
        </div>
    </section>
}
