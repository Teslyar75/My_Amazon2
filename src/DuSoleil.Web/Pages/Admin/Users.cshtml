@page
@model DuSoleil.Web.Pages.Admin.UsersModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Users";
}

<div class="admin-top">
    <h1>Пользователи</h1>
    <div class="admin-top-actions">
        <a class="btn btn-ghost" asp-page="/Admin/Index">← Dashboard</a>
    </div>
</div>

<section class="admin-card">
    <table class="admin-table">
        <thead>
            <tr><th>Name</th><th>Email</th><th>Login</th><th>Role</th><th>Registered</th></tr>
        </thead>
        <tbody>
        @foreach (var u in Model.Rows)
        {
            <tr>
                <td>@u.Name</td>
                <td>@u.Email</td>
                <td><code>@u.Login</code></td>
                <td>@u.Role</td>
                <td>@u.RegisteredAtUtc.ToLocalTime().ToString("g")</td>
            </tr>
        }
        </tbody>
    </table>
</section>
