@page
@model DuSoleil.Web.Pages.Admin.LoginModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Login";
}

<div class="admin-login">
    <h1>Du Soleil — Admin</h1>
    <p class="hint">Как в homework: логин <code>Admin</code>, пароль <code>Admin</code></p>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert-error">@Model.Error</div>
    }

    <form method="post" class="admin-form">
        <label>
            Login
            <input asp-for="Login" autocomplete="username" required />
        </label>
        <label>
            Password
            <input asp-for="Password" type="password" autocomplete="current-password" required />
        </label>
        <button type="submit" class="btn btn-primary">Sign in</button>
    </form>

    <p><a asp-page="/Index">← Back to store</a></p>
</div>
