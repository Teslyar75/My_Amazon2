@page
@model DuSoleil.Web.Pages.Admin.OrdersModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Orders";
}

<div class="admin-top">
    <h1>Заказы</h1>
    <div class="admin-top-actions">
        <a class="btn btn-ghost" asp-page="/Admin/Index">← Dashboard</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-ok">@Model.Message</div>
}

<section class="admin-card">
    @if (Model.Orders.Count == 0)
    {
        <p class="empty-state">Заказов пока нет.</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Покупатель</th>
                    <th>Дата</th>
                    <th>Позиции</th>
                    <th>Сумма</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var o in Model.Orders)
            {
                <tr>
                    <td><code>@o.Id.ToString()[..8]</code></td>
                    <td>@(o.User?.Name ?? o.UserId.ToString()[..8])</td>
                    <td>@o.OrderDateUtc.ToLocalTime().ToString("g")</td>
                    <td>@o.ItemsCount</td>
                    <td>$@o.TotalAmount.ToString("0.00")</td>
                    <td>
                        <form method="post" asp-page-handler="Status" class="inline-status">
                            <input type="hidden" name="id" value="@o.Id" />
                            <select name="status" onchange="this.form.submit()">
                                @foreach (OrderStatus s in Enum.GetValues<OrderStatus>())
                                {
                                    if (o.Status == s)
                                    {
                                        <option value="@s" selected>@s</option>
                                    }
                                    else
                                    {
                                        <option value="@s">@s</option>
                                    }
                                }
                            </select>
                        </form>
                    </td>
                    <td>
                        <a asp-page="/Orders/Details" asp-route-id="@o.Id">Открыть</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
