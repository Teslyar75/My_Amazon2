@page "{id:guid}"
@model DuSoleil.Web.Pages.Admin.EditModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit product";
}

<div class="admin-top">
    <h1>Редактирование товара</h1>
    <div class="admin-top-actions">
        <a class="btn btn-ghost" asp-page="/Admin/Index">← Dashboard</a>
        <a class="btn btn-ghost" asp-page="/Products/Details" asp-route-id="@Model.Id">На витрине</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-ok">@Model.Message</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-error">@Model.Error</div>
}

<section class="admin-card">
    <form method="post" enctype="multipart/form-data" class="admin-form">
        <label>Название *
            <input asp-for="Form.Name" required />
        </label>
        <label>Описание
            <textarea asp-for="Form.Description" rows="4"></textarea>
        </label>
        <div class="form-row">
            <label>SKU <input asp-for="Form.Sku" /></label>
            <label>Slug <input asp-for="Form.Slug" placeholder="roku-express-4k" /></label>
            <label>Brand <input asp-for="Form.Brand" /></label>
        </div>
        <div class="form-row">
            <label>Price <input asp-for="Form.Price" type="number" step="0.01" min="0" /></label>
            <label>Old price <input asp-for="Form.OldPrice" type="number" step="0.01" min="0" /></label>
            <label>Stock <input asp-for="Form.StockQuantity" type="number" min="0" /></label>
        </div>
        <label>Категория *
            <select asp-for="Form.CategoryId" required>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
        </label>
        <div class="form-row">
            <label>Status
                <select asp-for="Form.Status" asp-items="Html.GetEnumSelectList<ProductStatus>()"></select>
            </label>
            <label class="checkbox-row">
                <input asp-for="Form.IsBestSeller" /> Best seller
            </label>
        </div>
        @if (!string.IsNullOrEmpty(Model.CurrentImageUrl))
        {
            <div class="edit-preview">
                <img src="@Model.CurrentImageUrl" alt="Current" width="120" />
            </div>
        }
        <label>Новое изображение
            <input asp-for="Form.Image" type="file" accept="image/*" />
        </label>
        <button type="submit" class="btn btn-primary">Сохранить</button>
    </form>
</section>
