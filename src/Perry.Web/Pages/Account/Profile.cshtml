@page
@model Perry.Web.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "My profile";
    var u = Model.Account!;
}

<div class="page-wrap">
    <h1>My profile</h1>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-ok">@Model.Message</div>
    }
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert-error">@Model.Error</div>
    }

    <section class="admin-card profile-card">
        <h2>Account</h2>
        <div class="buy-row"><span>Login</span><span>@Model.LoginName</span></div>
        <div class="buy-row"><span>Role</span><span>@Model.RoleId</span></div>
        <div class="buy-row"><span>Registered</span><span>@u.RegisteredAtUtc.ToLocalTime().ToString("d")</span></div>
        <div class="buy-row"><span>Orders</span><span>@Model.TotalOrders</span></div>

        <form method="post" asp-page-handler="Update" class="admin-form" style="margin-top:16px">
            <label>Name <input asp-for="EditName" required /></label>
            <label>Email <input asp-for="EditEmail" type="email" required /></label>
            <button class="btn btn-primary" type="submit">Save changes</button>
        </form>

        <form method="post" asp-page-handler="Delete" style="margin-top:16px"
              onsubmit="return confirm('Удалить аккаунт (soft-delete)?')">
            <button class="btn btn-danger" type="submit">Delete account</button>
        </form>
    </section>

    <section class="section">
        <div class="section-head">
            <h2>Recent orders</h2>
            <a asp-page="/Orders/Index">See all →</a>
        </div>
        @if (Model.RecentOrders.Count == 0)
        {
            <p class="empty-state">No orders yet. <a asp-page="/Products/Index">Shop now</a></p>
        }
        else
        {
            <table class="admin-table">
                <thead>
                    <tr><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    <tr>
                        <td>@o.OrderDateUtc.ToLocalTime().ToString("g")</td>
                        <td>@o.ItemsCount</td>
                        <td>$@o.TotalAmount.ToString("0.00")</td>
                        <td>@o.Status</td>
                        <td><a asp-page="/Orders/Details" asp-route-id="@o.Id">Details</a></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
</div>
