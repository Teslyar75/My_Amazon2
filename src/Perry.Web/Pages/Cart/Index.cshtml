@page
@model Perry.Web.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Cart";
}

<div class="page-wrap">
    <h1>Shopping cart</h1>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-ok">@Model.Message</div>
    }
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert-error">@Model.Error</div>
    }

    @if (Model.Items.Count == 0)
    {
        <div class="empty-state cart-empty">
            <h2>Your cart is empty</h2>
            <p>Browse the catalog and add something you like.</p>
            <a class="btn btn-primary" asp-page="/Products/Index">Go to catalog</a>
            @if (!Model.IsAuthenticated)
            {
                <p class="guest-hint">Not logged in — <a asp-page="/Account/Login">Sign in</a> to keep cart across devices.</p>
            }
        </div>
    }
    else
    {
        <div class="cart-layout">
            <div class="cart-items">
                @foreach (var item in Model.Items)
                {
                    var img = item.Product.Images.FirstOrDefault(i => i.IsPrimary)?.Url
                        ?? item.Product.Images.OrderBy(i => i.SortOrder).FirstOrDefault()?.Url;
                    <article class="cart-row">
                        <a class="cart-row__img" asp-page="/Products/Details" asp-route-id="@item.ProductId">
                            @if (!string.IsNullOrEmpty(img))
                            {
                                <img src="@img" alt="@item.Product.Name" />
                            }
                            else
                            {
                                <div class="img-placeholder"></div>
                            }
                        </a>
                        <div class="cart-row__info">
                            <a asp-page="/Products/Details" asp-route-id="@item.ProductId">@item.Product.Name</a>
                            <div class="muted">$@item.Product.Price.ToString("0.00")</div>
                            <form method="post" asp-page-handler="Update" class="qty-form">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <label>Qty
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" />
                                </label>
                                <button class="btn btn-ghost" type="submit">Update</button>
                            </form>
                            <form method="post" asp-page-handler="Remove">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button class="btn btn-link" type="submit">Remove</button>
                            </form>
                        </div>
                        <div class="cart-row__sum">
                            <strong>$@((item.Quantity * item.Product.Price).ToString("0.00"))</strong>
                        </div>
                    </article>
                }
            </div>

            <aside class="cart-summary">
                <h2>Order summary</h2>
                <div class="buy-row"><span>Items</span><span>@Model.Items.Sum(i => i.Quantity)</span></div>
                <div class="buy-row"><span>Total</span><strong>$@Model.Total.ToString("0.00")</strong></div>

                @if (Model.IsAuthenticated)
                {
                    <form method="post" asp-page-handler="Checkout">
                        <button class="btn btn-primary" type="submit" style="width:100%">Proceed to checkout</button>
                    </form>
                }
                else
                {
                    <p class="guest-hint">Sign in to place an order.</p>
                    <a class="btn btn-primary" asp-page="/Account/Login" asp-route-returnUrl="/Cart">Sign in</a>
                    <a class="btn btn-ghost" asp-page="/Account/Register">Create account</a>
                }
            </aside>
        </div>
    }

    <partial name="_ViewedProducts" model="Model.ViewedProducts" />
</div>
