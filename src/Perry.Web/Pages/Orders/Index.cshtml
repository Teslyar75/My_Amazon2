@page
@model Perry.Web.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "My orders";
}

<div class="page-wrap">
    <h1>Order history</h1>
    @if (Model.Orders.Count == 0)
    {
        <div class="empty-state">No orders yet. <a asp-page="/Products/Index">Shop now</a></div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var o in Model.Orders)
            {
                <tr>
                    <td>@o.OrderDateUtc.ToLocalTime().ToString("g")</td>
                    <td>@o.ItemsCount</td>
                    <td>$@o.TotalAmount.ToString("0.00")</td>
                    <td>@o.Status</td>
                    <td><a asp-page="/Orders/Details" asp-route-id="@o.Id">Details</a></td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
