@page
@model Perry.Web.Pages.Admin.LoginModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Admin Login";
    var hasError = !string.IsNullOrEmpty(Model.Error);
}

<a class="auth-back" asp-page="/Index">← Back to store</a>

<div class="auth-modal">
    <div class="auth-modal__body">
        <div class="auth-modal__form-col">
            @if (hasError)
            {
                <div class="auth-alert">@Model.Error</div>
            }

            <form method="post" class="login-form" novalidate>
                <div class="login-form__titles">
                    <h1>Welcome back</h1>
                    <h2>Login into admin account</h2>
                </div>

                <div class="login-form__fields">
                    <div class="perry-field @(hasError ? "perry-field--error" : null)">
                        <span class="perry-field__label">Login</span>
                        <input class="perry-field__input"
                               asp-for="Login"
                               type="text"
                               placeholder="Enter your login"
                               autocomplete="username"
                               required />
                    </div>

                    <div class="perry-field perry-field--password">
                        <span class="perry-field__label">Password</span>
                        <input class="perry-field__input"
                               asp-for="Password"
                               type="password"
                               placeholder="Enter your password"
                               autocomplete="current-password"
                               data-password-input
                               required />
                        <button type="button"
                                class="perry-field__toggle"
                                data-password-toggle
                                data-icon-open="@Url.Content("~/icons/Eye_open.svg")"
                                data-icon-closed="@Url.Content("~/icons/Eye_closed.svg")"
                                aria-label="Show password">
                            <img src="@Url.Content("~/icons/Eye_closed.svg")" alt="Show password" width="24" height="24" />
                        </button>
                    </div>

                    <div class="login-form__row">
                        <label class="login-form__remember">
                            <input type="checkbox" name="StaySignedIn" value="true" />
                            Stay signed in
                        </label>
                        <span class="login-form__forgot">Admin / Admin</span>
                    </div>
                </div>

                <button type="submit" class="perry-btn">Log in</button>
            </form>
        </div>

        <div class="auth-modal__image">
            <img src="@Url.Content("~/images/SiginSignup.png")" alt="Admin sign in" width="530" height="632" />
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/auth.js" asp-append-version="true"></script>
}
