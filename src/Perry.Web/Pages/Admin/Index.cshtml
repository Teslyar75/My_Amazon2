@page
@model Perry.Web.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="admin-top">
    <h1>Админ панель / Dashboard</h1>
    <div class="admin-top-actions">
        <a class="btn btn-ghost" asp-page="/Admin/Orders">Заказы</a>
        <a class="btn btn-ghost" asp-page="/Admin/Users">Пользователи</a>
        <a class="btn btn-ghost" asp-page="/Index">← В магазин</a>
        <a class="btn btn-ghost" href="?logout=1">Выход</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-ok">@Model.Message</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-error">@Model.Error</div>
}

<div class="stats-grid">
    <div class="stat-card"><span>Товары</span><strong>@Model.ProductsCount</strong></div>
    <div class="stat-card"><span>Категории</span><strong>@Model.CategoriesCount</strong></div>
    <div class="stat-card"><span>Out of stock</span><strong>@Model.OutOfStockCount</strong></div>
    <div class="stat-card"><span>Отзывы</span><strong>@Model.ReviewsCount</strong></div>
</div>

<div class="admin-grid">
    <section class="admin-card">
        <h2>Создать категорию</h2>
        <form method="post" asp-page-handler="CreateCategory" enctype="multipart/form-data" class="admin-form">
            <label>Название *
                <input asp-for="NewCategory.Name" required />
            </label>
            <label>Slug *
                <input asp-for="NewCategory.Slug" placeholder="electronics" required />
            </label>
            <label>Родительская категория
                <select asp-for="NewCategory.ParentCategoryId">
                    <option value="">— нет (корневая) —</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </label>
            <label>Sort order
                <input asp-for="NewCategory.SortOrder" type="number" />
            </label>
            <label>Изображение
                <input asp-for="NewCategory.Image" type="file" accept="image/*" />
            </label>
            <button type="submit" class="btn btn-primary">Создать категорию</button>
        </form>
    </section>

    <section class="admin-card">
        <h2>Создать товар</h2>
        <form method="post" asp-page-handler="CreateProduct" enctype="multipart/form-data" class="admin-form">
            <label>Название *
                <input asp-for="NewProduct.Name" required />
            </label>
            <label>Описание
                <textarea asp-for="NewProduct.Description" rows="3"></textarea>
            </label>
            <label>Категория *
                <select asp-for="NewProduct.CategoryId" required>
                    <option value="">— выберите —</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </label>
            <div class="form-row">
                <label>SKU
                    <input asp-for="NewProduct.Sku" placeholder="авто" />
                </label>
                <label>Бренд
                    <input asp-for="NewProduct.Brand" />
                </label>
            </div>
            <div class="form-row">
                <label>Цена *
                    <input asp-for="NewProduct.Price" type="number" step="0.01" min="0" required />
                </label>
                <label>Старая цена
                    <input asp-for="NewProduct.OldPrice" type="number" step="0.01" min="0" />
                </label>
                <label>Остаток
                    <input asp-for="NewProduct.StockQuantity" type="number" min="0" />
                </label>
            </div>
            <label>Изображение
                <input asp-for="NewProduct.Image" type="file" accept="image/*" />
            </label>
            <button type="submit" class="btn btn-primary">Создать товар</button>
        </form>
    </section>
</div>

<section class="admin-card">
    <h2>Категории (@Model.Categories.Count)</h2>
    <table class="admin-table">
        <thead>
            <tr><th>Name</th><th>Slug</th><th>Parent</th><th>Active</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var c in Model.Categories)
        {
            var parent = Model.Categories.FirstOrDefault(x => x.Id == c.ParentCategoryId)?.Name ?? "—";
            <tr>
                <td>@c.Name</td>
                <td><code>@c.Slug</code></td>
                <td>@parent</td>
                <td>@(c.IsActive ? "yes" : "no")</td>
                <td>
                    @if (c.IsActive)
                    {
                        <form method="post" asp-page-handler="DeactivateCategory" asp-route-id="@c.Id" style="display:inline">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Деактивировать категорию?')">Deactivate</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="ActivateCategory" asp-route-id="@c.Id" style="display:inline">
                            <button type="submit" class="btn btn-ghost">Activate</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

<section class="admin-card">
    <h2>Товары (последние @Model.Products.Count)</h2>
    <table class="admin-table">
        <thead>
            <tr><th>Name</th><th>SKU</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var p in Model.Products)
        {
            <tr>
                <td>
                    <a asp-page="/Products/Details" asp-route-id="@p.Id">@p.Name</a>
                </td>
                <td><code>@p.Sku</code></td>
                <td>@p.Category?.Name</td>
                <td>$@p.Price.ToString("0.00")</td>
                <td>@p.StockQuantity</td>
                <td>@p.Status</td>
                <td class="admin-row-actions">
                    <a class="btn btn-ghost" asp-page="/Admin/Edit" asp-route-id="@p.Id">Edit</a>
                    @if (p.Status == Perry.Domain.Enums.ProductStatus.Archived)
                    {
                        <form method="post" asp-page-handler="RestoreProduct" asp-route-id="@p.Id" style="display:inline">
                            <button type="submit" class="btn btn-ghost">Restore</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="DeleteProduct" asp-route-id="@p.Id" style="display:inline">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Архивировать товар?')">Archive</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
